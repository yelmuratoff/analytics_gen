    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@rjsf/core": "^6.4.1",
    "@rjsf/mui": "^6.4.1",
    "@rjsf/utils": "^6.4.1",
    "@rjsf/validator-ajv8": "^6.4.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "file-saver": "^2.0.5",
    "immer": "^11.1.4",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
