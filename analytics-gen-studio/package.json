{
  "name": "analytics-gen-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-schemas": "cp ../schema/*.json public/schemas/",
    "generate-types": "node scripts/generate-types.mjs",
    "build": "npm run copy-schemas && npm run generate-types && tsc -b && vite build",
